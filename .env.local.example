# UC Remote 3 deploy credentials.
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
#
# UC3_HOST: IP (or hostname) of your UC Remote 3 on the local network
# UC3_USER: web-configurator (default, rarely changes)
# UC3_PIN:  shown in device settings → Developer Options
#
# Usage in shell scripts and deploy commands:
#   set -a; source .env.local; set +a
#   curl "http://${UC3_HOST}/api/system/install/ui?void_warranty=yes" \
#     --form "file=@/tmp/remote-ui-deploy.tar.gz" \
#     -u "${UC3_USER}:${UC3_PIN}"

UC3_HOST=
UC3_USER=web-configurator
UC3_PIN=
